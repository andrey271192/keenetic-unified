HOST=0.0.0.0
PORT=8000
ADMIN_PASSWORD=admin

# Подпись автора в углу веб-интерфейса (username без @; строка пустая = скрыть; строку можно убрать — тогда @Iot_andrey)
AUTHOR_TELEGRAM_USERNAME=Iot_andrey

# Telegram
TELEGRAM_TOKEN=PUT_TOKEN_HERE
TELEGRAM_CHAT_ID=PUT_CHAT_ID_HERE

# Optional SMTP (defaults exist in config.py, override if needed)
# SMTP_USER=
# SMTP_PASS=
# SMTP_TO=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
